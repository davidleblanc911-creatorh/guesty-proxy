// Fetch réservations via proxy Render
async function fetchReservations(){
// Token
const tokR=await fetch(`${PROXY}/token`,{
method:“POST”,
headers:{“Content-Type”:“application/json”},
body:JSON.stringify({clientId:CLIENT_ID,clientSecret:CLIENT_SECRET})
});
if(!tokR.ok) throw new Error(`Token ${tokR.status}`);
const tokJ=await tokR.json();
const token=tokJ.access_token;
if(!token) throw new Error(“Pas de token: “+JSON.stringify(tokJ));

// Réservations
const filters=JSON.stringify([
{operator:”$gte”,field:“checkInDateLocalized”,value:“2025-01-01”},
{operator:”$lte”,field:“checkInDateLocalized”,value:“2026-12-31”},
{operator:”$in”,field:“status”,value:[“confirmed”,“reserved”]}
]);
const fields=”_id confirmationCode checkInDateLocalized checkOutDateLocalized createdAt integration source money.fareAccommodation money.hostPayout listingId listing.nickname”;

let all=[],skip=0;
while(true){
const params=new URLSearchParams({fields,filters,limit:100,skip,sort:“checkInDateLocalized”});
const r=await fetch(`${PROXY}/reservations?${params}`,{headers:{Authorization:`Bearer ${token}`}});
if(!r.ok) throw new Error(`Réservations ${r.status}`);
const j=await r.json();
const results=j.results||j.data||[];
all=[…all,…results];
if(results.length<100) break;
skip+=100;
}
return all;
}

function mapRes(raw){
return raw.map((r,i)=>{
const ci=new Date(r.checkInDateLocalized);
const co=new Date(r.checkOutDateLocalized);
const nights=Math.max(1,Math.round((co-ci)/86400000));
const platform=(r.integration?.platform||“manual”).toLowerCase();
const source=(r.source||“manual”).toLowerCase();
const type=detectType(platform,source,ci);
const gross=r.money?.fareAccommodation||r.money?.hostPayout||0;
const fin=calcFin(type,gross);
const bk=new Date(r.createdAt||ci);
const lead=Math.max(0,Math.round((ci-bk)/86400000));
// Mapper les listing IDs aux noms de propriétés
const nick=(r.listing?.nickname||””).toLowerCase();
let propId=r.listingId;
if(nick.includes(“188”)||nick.includes(“sommer”)||nick.includes(“bleu”)) propId=“188”;
else if(nick.includes(“250”)||nick.includes(“blue hill”)) propId=“250”;
else if(nick.includes(“1540”)||nick.includes(“lodge”)||nick.includes(“howard”)) propId=“1540”;
return{id:r._id||`G${i}`,propId,listingName:r.listing?.nickname||r.listingId,
checkIn:ci,checkOut:co,bookingDate:bk,nights,gross,platform,source,type,…fin,
adr:Math.round((fin.net/nights)*100)/100,leadTime:lead,future:ci>TODAY,
confirmationCode:r.confirmationCode};
});
}

