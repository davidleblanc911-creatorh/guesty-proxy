const CUTOFF=new Date(“2025-10-01”),TODAY=new Date(“2026-04-05”);

function detectType(platform,source,checkInDate){
const p=(platform||””).toLowerCase(),s=(source||””).toLowerCase();
const d=checkInDate instanceof Date?checkInDate:new Date(checkInDate);
if(p===“airbnb”||p.includes(“airbnb”)) return d<CUTOFF?“airbnb_old”:“airbnb_new”;
if(s===“cash”||s===“comptant”||s===“manual_cash”) return “cash”;
return “direct_guesty”;
}

function calcFin(type,gross){
let hostFee=0,tps=0,tvq=0,taxHeberg=0,guestyFee=0;
if(type===“airbnb_old”){hostFee=gross*AIRBNB_OLD;tps=gross*TPS;tvq=gross*TVQ;}
if(type===“airbnb_new”){hostFee=gross*AIRBNB_NEW;tps=gross*TPS;tvq=gross*TVQ;}
if(type===“direct_guesty”){tps=gross*TPS;tvq=gross*TVQ;taxHeberg=gross*TAXE_HEBERG;guestyFee=gross*GUESTY_FEE;}
const net=gross-hostFee-tps-tvq-taxHeberg-guestyFee;
const r=v=>Math.round(v*100)/100;
return{hostFee:r(hostFee),tps:r(tps),tvq:r(tvq),taxHeberg:r(taxHeberg),guestyFee:r(guestyFee),net:r(net)};
}

