if(mode===“trim_complet”) return{label:`T${q+1} ${y}`,from:new Date(y,q*3,1),to:new Date(y,q*3+3,0)};
if(mode===“trim_ce_jour”) return{label:`T${q+1} ${y} (à ce jour)`,from:new Date(y,q*3,1),to:new Date(y,m,d)};
return QUARTERS[mode]||QUARTERS[4];
