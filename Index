  {/* Indicateur période */}
  <div style={{padding:"8px 20px",fontSize:11,color:C.textDim,fontFamily:"monospace",background:"#080f0a",borderBottom:`1px solid ${C.border}`}}>
    📅 <span style={{color:C.textMid}}>{Q.label}</span> · {DT(Q.from)} → {DT(Q.to)}
    {compareMode&&prevQ&&<span style={{marginLeft:16}}>vs <span style={{color:C.textMid}}>{prevQ.label}</span></span>}
  </div>

  {/* Comparaison */}
  {compareMode&&prevQ&&T.net>0&&(
    <div style={{background:"#0c1a10",borderBottom:`1px solid ${C.border}`,padding:"10px 20px",display:"flex",gap:20,flexWrap:"wrap",alignItems:"center"}}>
      <span style={{fontSize:11,color:C.textDim,fontFamily:"monospace"}}>⇆ {prevQ.label} → {Q.label}</span>
      {[["Net",Tp.net,T.net],["Brut",Tp.gross,T.gross],["Rés.",Tp.count,T.count],["Nuits",Tp.nights,T.nights]].map(([l,p,c])=>{
        const d=p>0?((c-p)/p)*100:0;
        return(
          <div key={l} style={{display:"flex",alignItems:"center",gap:6}}>
            <span style={{fontSize:12,color:C.textMid}}>{l}</span>
            <span style={{fontSize:12,fontFamily:"monospace",color:d>0?C.green:d<0?C.red:C.textDim,background:d>0?"#0a2a14":d<0?"#2a0a0a":"transparent",borderRadius:4,padding:"1px 6px"}}>
              {d>0?"+":""}{d.toFixed(1)}%
            </span>
          </div>
        );
      })}
    </div>
  )}

  <div style={{padding:"14px 20px",display:"flex",flexDirection:"column",gap:12}}>

    {/* KPI financiers */}
    <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(140px,1fr))",gap:8}}>
      <KPI label="Revenu net" value={CAD(T.net)} sub={`${res.length} rés. · ${T.nights} nuits`} hi delta={compareMode?delta(T.net,Tp.net):undefined}/>
      <KPI label="Revenu brut" value={CAD(T.gross)} sub="Avant déductions" delta={compareMode?delta(T.gross,Tp.gross):undefined}/>
      <KPI label="Frais plateforme" value={CAD(T.fees)} sub="Airbnb 3% ou 15.5%"/>
      <KPI label="TPS collectée" value={CAD(T.tps)} sub="À remettre" warn/>
      <KPI label="TVQ collectée" value={CAD(T.tvq)} sub="À remettre" warn/>
      <KPI label="Taxe héberg." value={CAD(T.heberg)} sub="3.5% QC — Direct" warn/>
      <KPI label="Frais Guesty" value={CAD(T.guesty)} sub="2.9% — Direct"/>
    </div>

    {/* KPI locatifs */}
    <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(140px,1fr))",gap:8}}>
      <KPI label="Taux d'occupation" value={`${occupancy.toFixed(1)}%`} sub={`${T.nights}/${Math.round(daysInPer*props.length)} nuits`}/>
      <KPI label="ADR net / nuit" value={CAD2(ADR)} sub="Net moy. par nuit"/>
      <KPI label="Durée moy." value={`${res.length>0?(T.nights/res.length).toFixed(1):0} nuits`} sub="Par réservation"/>
      <KPI label="Lead time" value={`${Math.round(res.filter(r=>!r.future).reduce((s,r,_,a)=>s+r.leadTime/a.length,0))}j`} sub="Résa → arrivée"/>
      <KPI label="Futures" value={futureRes.length} sub={`${CAD(futureRes.reduce((s,r)=>s+r.net,0))} prévu`}/>
    </div>

    {/* TABS */}
    <div style={{display:"flex",gap:5,flexWrap:"wrap"}}>
      {["overview","graphiques","propriétés","réservations"].map(t=>(
        <button key={t} style={{...chip(tab===t),borderRadius:7}} onClick={()=>setTab(t)}>
          {t.charAt(0).toUpperCase()+t.slice(1)}
        </button>
      ))}
    </div>

    {/* OVERVIEW */}
    {tab==="overview"&&(
      <div style={{display:"flex",flexDirection:"column",gap:12}}>
        <div style={card}>
          <div style={sec}>Revenu net par propriété</div>
          {propStats.map(p=><Bar2 key={p.id} label={p.nom} value={p.net} pct={(p.net/maxNet)*100}/>)}
          {propStats.length===0&&<div style={{color:C.textDim,fontSize:13}}>Aucune donnée pour cette période.</div>}
        </div>
        <div style={card}>
          <div style={sec}>Par type de réservation</div>
          {Object.entries(typeStats).filter(([,v])=>v.count>0).map(([k,v])=>(
            <Bar2 key={k} label={`${TYPE_SHORT[k]} — ${v.count} rés.`} value={v.net} pct={T.net>0?(v.net/T.net)*100:0} color={TYPE_COLOR[k]}/>
          ))}
        </div>
      </div>
    )}

    {/* GRAPHIQUES */}
    {tab==="graphiques"&&(
      <div style={{display:"flex",flexDirection:"column",gap:12}}>
        <div style={{display:"flex",gap:8,marginBottom:4}}>
          {[2025,2026].map(y=><button key={y} style={chip(chartYear===y)} onClick={()=>setChartYear(y)}>{y}</button>)}
        </div>
        <div style={card}>
          <div style={sec}>Revenu net vs brut — mensuel {chartYear}</div>
          <ResponsiveContainer width="100%" height={220}>
            <LineChart data={monthlyData} margin={{top:5,right:10,left:0,bottom:5}}>
              <CartesianGrid strokeDasharray="3 3" stroke="#162318"/>
              <XAxis dataKey="month" tick={{fill:C.textDim,fontSize:10}} axisLine={{stroke:C.border}}/>
              <YAxis tick={{fill:C.textDim,fontSize:10}} tickFormatter={v=>CAD(v)} width={75} axisLine={{stroke:C.border}}/>
              <Tooltip content={<ChartTip/>}/>
              <Legend wrapperStyle={{fontSize:12}}/>
              <Line type="monotone" dataKey="gross" name="Brut" stroke={C.textMid} strokeWidth={1.5} dot={false}/>
              <Line type="monotone" dataKey="net" name="Net" stroke={C.green} strokeWidth={2.5} dot={{r:3,fill:C.green}}/>
            </LineChart>
          </ResponsiveContainer>
        </div>
        <div style={card}>
          <div style={sec}>Réservations par mois {chartYear}</div>
          <ResponsiveContainer width="100%" height={160}>
            <BarChart data={monthlyData} margin={{top:5,right:10,left:0,bottom:5}}>
              <CartesianGrid strokeDasharray="3 3" stroke="#162318"/>
              <XAxis dataKey="month" tick={{fill:C.textDim,fontSize:10}} axisLine={{stroke:C.border}}/>
              <YAxis tick={{fill:C.textDim,fontSize:10}} axisLine={{stroke:C.border}}/>
              <Tooltip content={<ChartTip/>}/>
              <Bar dataKey="count" name="Réservations" fill={C.blue} radius={[3,3,0,0]}/>
            </BarChart>
          </ResponsiveContainer>
        </div>
      </div>
    )}

    {/* PROPRIÉTÉS */}
    {tab==="propriétés"&&(
      <div style={card}>
        <div style={{overflowX:"auto"}}>
          <table style={{width:"100%",borderCollapse:"collapse"}}>
            <thead><tr>
              {["Propriété","Brut","Frais","TPS","TVQ","Héberg.","Net","Rés.","Nuits","ADR"].map(h=>(
                <th key={h} style={{...th,textAlign:h==="Propriété"?"left":"right"}}>{h}</th>
              ))}
            </tr></thead>
            <tbody>
              {propStats.map(p=>(
                <tr key={p.id}>
                  <td style={td}><span style={{fontWeight:600}}>{p.nom}</span></td>
                  <td style={tdr}>{CAD(p.gross)}</td>
                  <td style={{...tdr,color:C.amber}}>{CAD(p.fees)}</td>
                  <td style={{...tdr,color:C.red}}>{CAD(p.tps)}</td>
                  <td style={{...tdr,color:C.red}}>{CAD(p.tvq)}</td>
                  <td style={{...tdr,color:C.orange}}>{p.heberg>0?CAD(p.heberg):"—"}</td>
                  <td style={{...tdr,color:C.green,fontWeight:700}}>{CAD(p.net)}</td>
                  <td style={tdr}>{p.count}</td>
                  <td style={tdr}>{p.nights}</td>
                  <td style={{...tdr,color:C.textMid}}>{CAD2(p.nights>0?p.net/p.nights:0)}</td>
                </tr>
              ))}
              <tr style={{background:"#0f1c12"}}>
                <td style={{...td,fontWeight:700}}>TOTAL</td>
                <td style={{...tdr,fontWeight:700}}>{CAD(T.gross)}</td>
                <td style={{...tdr,color:C.amber,fontWeight:700}}>{CAD(T.fees)}</td>
                <td style={{...tdr,color:C.red,fontWeight:700}}>{CAD(T.tps)}</td>
                <td style={{...tdr,color:C.red,fontWeight:700}}>{CAD(T.tvq)}</td>
                <td style={{...tdr,color:C.orange,fontWeight:700}}>{CAD(T.heberg)}</td>
                <td style={{...tdr,color:C.green,fontWeight:700}}>{CAD(T.net)}</td>
                <td style={{...tdr,fontWeight:700}}>{res.length}</td>
                <td style={{...tdr,fontWeight:700}}>{T.nights}</td>
                <td style={{...tdr,color:C.textMid,fontWeight:700}}>{CAD2(ADR)}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    )}

    {/* RÉSERVATIONS */}
    {tab==="réservations"&&(
      <div style={card}>
        <div style={{marginBottom:10,fontSize:12,color:C.textDim}}>{res.length} réservations · Net {CAD(T.net)}</div>
        <div style={{overflowX:"auto"}}>
          <table style={{width:"100%",borderCollapse:"collapse"}}>
            <thead><tr>
              {["Propriété","Type","Check-in","Check-out","Nuits","Brut","Frais","Net"].map(h=>(
                <th key={h} style={{...th,textAlign:["Propriété","Type","Check-in","Check-out"].includes(h)?"left":"right"}}>{h}</th>
              ))}
            </tr></thead>
            <tbody>
              {res.slice(0,100).map(r=>(
                <tr key={r.id} style={{background:r.future?"#0c1a0e":"transparent"}}>
                  <td style={{...td,maxWidth:130,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{r.listingName||PROP_NOTES[r.propId]||r.propId}</td>
                  <td style={td}><Badge type={r.type}/></td>
                  <td style={{...td,fontFamily:"monospace",fontSize:11}}>{DT(r.checkIn)}</td>
                  <td style={{...td,fontFamily:"monospace",fontSize:11}}>{DT(r.checkOut)}</td>
                  <td style={tdr}>{r.nights}</td>
                  <td style={tdr}>{CAD2(r.gross)}</td>
                  <td style={{...tdr,color:C.amber}}>{r.hostFee>0?CAD2(r.hostFee):"—"}</td>
                  <td style={{...tdr,color:C.green,fontWeight:700}}>{CAD2(r.net)}</td>
                </tr>
              ))}
            </tbody>
          </table>
          {res.length>100&&<div style={{textAlign:"center",padding:10,color:C.textDim,fontSize:12}}>+{res.length-100} autres</div>}
        </div>
      </div>
    )}

  </div>
</div>
```

